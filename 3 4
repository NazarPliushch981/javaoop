            constructor(r) { this.radius = r; }
            get r() { return this.radius; }
            set r(value) { this.radius = value; }
            get d() { return this.radius * 2; }
            calcArea() { return Math.PI * this.radius * this.radius; }
            calcLength() { return 2 * Math.PI * this.radius; }
        }

